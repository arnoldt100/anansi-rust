<?xml version="1.0" encoding="UTF-8"?>
<root>
    <restart>
        <!-- Indicates if this is a restart of a previous simulation. This
        element can have 2 possible values: "yes" or "no". value of "yes"
        indicates this simulation is a restart of a previous simulation. A
        value of "no" indicates that a that this simulation instance is new.
        The default value is "no". --> 
        no
    </restart>

    <stage stage_no="0">
        <description> Stage 0 of the simulation. </description>
    </stage>

    <stage stage_no="1">
        <description> Stage 1 of the simulation. </description>
    </stage>

    <stage stage_no="2">
        <description> Stage 2 of the simulation. </description>
    </stage>

</root>
